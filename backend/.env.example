# Database
DATABASE_URL="postgresql://user:password@localhost:5432/filliq?schema=public"

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# WhatsApp Business API (360dialog or Vonage)
WABA_PROVIDER=360dialog
WABA_PHONE_NUMBER_ID=your_phone_number_id
WABA_ACCESS_TOKEN=your_access_token
WABA_VERIFY_TOKEN=filliq-verify-token

# Redis (for BullMQ queues)
REDIS_URL=redis://localhost:6379

# JWT Secret (if using custom auth)
JWT_SECRET=your-secret-key

# Logging
LOG_LEVEL=info
